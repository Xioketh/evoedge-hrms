generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  HR_DIRECTOR
  HR_MANAGER
  HR_EXECUTIVE
  TREASURY
  HOD
  EMPLOYEE
}

enum OfferStatus {
  QUEUED
  DRAFT                // Saved, but never attempted to send
  SEND_FAILED          // n8n/Email failed. Needs admin to click "Resend"
  SENT                 // Email successful. Waiting for candidate to respond
  CANDIDATE_ACCEPTED   // Candidate accepted. Waiting for Admin final confirmation
  CANDIDATE_DECLINED   // Candidate said no. (Terminal state)
  EXPIRED              // Time ran out. (Terminal state)
  COMPLETED            // Admin confirmed, user account created! (Terminal state)
  CANCELLED            // Admin withdrew the offer at any point
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

model Company {
  id          String       @id @default(cuid())
  name        String       @unique
  domain      String?      @unique
  
  users       User[]
  departments Department[]
  offers      JobOffer[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Department {
  id          String            @id @default(cuid())
  name        String
  
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  profiles    EmployeeProfile[] 
  offers      JobOffer[]
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([name, companyId]) 
}

model User {
  id          String           @id @default(cuid())
  email       String           @unique
  password    String           // Ensure this is hashed (e.g., bcrypt/argon2)
  role        Role             @default(EMPLOYEE)
  
  // Tenant Isolation
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  profile     EmployeeProfile?
  
  // Soft Delete - Critical for HRM audit trails
  isActive    Boolean          @default(true)
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Composite index to speed up tenant-specific queries
  @@index([companyId, email])
}

model EmployeeProfile {
  id           String      @id @default(cuid())
  firstName    String
  lastName     String
  employeeCode String?     // Generated during onboarding
  
  // 1:1 Identity Relation
  userId       String      @unique
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Domain Relations
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  // Self-relation: Crucial for an HRM to establish reporting hierarchies
  managerId    String?
  manager      EmployeeProfile?  @relation("ReportingLine", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates EmployeeProfile[] @relation("ReportingLine")
  managedOffers JobOffer[] @relation("OfferManager")

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  // Enforce unique employee codes per company, not globally, to prevent collisions across tenants
  @@unique([employeeCode, userId]) 
}

model JobOffer {
  id              String         @id @default(cuid())
  
  // Public Portal Security: This UUID is the unguessable link for the candidate
  token           String         @unique @default(uuid()) 

  // Candidate Information
  firstName       String
  lastName        String
  email           String
  nicNumber       String

  // Employment Details
  jobPosition     String
  employmentType  EmploymentType @default(FULL_TIME)
  baseSalary      Decimal        @db.Decimal(10, 2)
  targetStartDate DateTime

  // Offer Content
  offerContent    String         @db.Text

  // State Management
  status          OfferStatus

  // Tenant Isolation (Mandatory for your architecture)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Domain Relations
  departmentId    String?
  department      Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  
  managerId       String?
  manager         EmployeeProfile? @relation("OfferManager", fields: [managerId], references: [id], onDelete: SetNull)

  // Audit Trail
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  respondedAt     DateTime?      // Captures exactly when candidate clicks Accept/Decline

  // Performance Optimization
  @@index([companyId])
  @@index([token])
}