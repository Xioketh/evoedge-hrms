generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  HR_DIRECTOR
  HR_MANAGER
  HR_EXECUTIVE
  TREASURY
  HOD
  EMPLOYEE
}

enum OfferStatus {
  QUEUED
  DRAFT                // Saved, but never attempted to send
  SEND_FAILED          // n8n/Email failed. Needs admin to click "Resend"
  SENT                 // Email successful. Waiting for candidate to respond
  CANDIDATE_ACCEPTED   // Candidate accepted. Waiting for Admin final confirmation
  CANDIDATE_DECLINED   // Candidate said no. (Terminal state)
  EXPIRED              // Time ran out. (Terminal state)
  COMPLETED            // Admin confirmed, user account created! (Terminal state)
  CANCELLED            // Admin withdrew the offer at any point
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

model Company {
  id          String       @id @default(cuid())
  name        String       @unique
  domain      String?      @unique
  
  users       User[]
  departments Department[]
  offers      JobOffer[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Department {
  id          String            @id @default(cuid())
  name        String
  
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  profiles    EmployeeProfile[] 
  offers      JobOffer[]
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([name, companyId]) 
}

model User {
  id          String           @id @default(cuid())
  email       String           @unique
  password    String           // Ensure this is hashed (e.g., bcrypt/argon2)
  role        Role             @default(EMPLOYEE)
  
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  
  profile     EmployeeProfile?

  createdOffers   JobOffer[]     @relation("OfferCreator")
  completedOffers JobOffer[] @relation("OfferCompleter")
  
  isActive    Boolean          @default(true)
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([companyId, email])
}

model EmployeeProfile {
  id           String      @id @default(cuid())
  firstName    String
  lastName     String
  employeeCode String?   @unique

  jobTitle       String?
  employmentType EmploymentType @default(FULL_TIME)

  baseSalary Decimal? @db.Decimal(12, 2)
  
  userId       String      @unique
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  managerId    String?
  manager      EmployeeProfile?  @relation("ReportingLine", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates EmployeeProfile[] @relation("ReportingLine")
  managedOffers JobOffer[] @relation("OfferManager")

  cvS3Key        String?   // S3 object key for the uploaded CV
  cvOriginalName String?   // Original filename preserved for download UX

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model JobOffer {
  id              String         @id @default(cuid())
  
  token           String         @unique @default(uuid()) 

  firstName       String
  lastName        String
  email           String
  nicNumber       String

  jobPosition     String
  employmentType  EmploymentType @default(FULL_TIME)
  baseSalary      Decimal        @db.Decimal(10, 2)
  targetStartDate DateTime

  offerContent    String         @db.Text

  s3ObjectKey     String?

  status          OfferStatus

  companyId       String
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  departmentId    String?
  department      Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  
  createdById     String?
  createdBy       User?          @relation("OfferCreator", fields: [createdById], references: [id], onDelete: SetNull)

  completedById   String?
  completedBy     User?      @relation("OfferCompleter", fields: [completedById], references: [id], onDelete: SetNull)
  completedAt     DateTime?

  managerId       String?
  manager         EmployeeProfile? @relation("OfferManager", fields: [managerId], references: [id], onDelete: SetNull)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  respondedAt     DateTime?      // Captures exactly when candidate clicks Accept/Decline

  @@index([companyId])
  @@index([token])
}